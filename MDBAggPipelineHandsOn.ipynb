    {
      "cell_type": "code",
      "source": [
        "# 🔧 Import Libraries\n",
        "from pymongo import MongoClient\n",
        "import json"
      ],
      "metadata": {
        "id": "BdPRuM1WHhWk"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# 🔌 Connect to MongoDB\n",
        "client = MongoClient(\"")\n",
        "db = client['sample_mflix']\n",
        "collection = db['movies']"
      ],
      "metadata": {
        "id": "QnRSgRluHmzT"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# 🔍 Run Query 1\n",
        "\n",
        "for document in collection.find(\n",
        "    {\"rated\": 'R'}\n",
        "  ).limit(5):\n",
        "    print(json.dumps(document, indent=4, default=str))\n"
      ],
      "metadata": {
        "collapsed": true,
        "id": "FF3j0IQrIppf"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# 🔍 Run Query 2\n",
        "\n",
        "for document in collection.find(\n",
        "    {\"year\": {\"$gt\": 2000}}\n",
        "  ).limit(5):\n",
        "    print(json.dumps(document, indent=4, default=str))\n"
      ],
      "metadata": {
        "id": "dbfJvLSGOZ0F"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# 🔍 Run Query 3\n",
        "\n",
        "for document in collection.find(\n",
        "    {\"cast\": \"Keanu Reeves\"}\n",
        "  ).limit(5):\n",
        "    print(json.dumps(document, indent=4, default=str))\n"
      ],
      "metadata": {
        "collapsed": true,
        "id": "A95Y6we9OaTQ"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# 🔍 Run Query 4\n",
        "\n",
        "for document in collection.find(\n",
        "    {\"genres\": {'$in': [\"Adventure\", \"Comedy\"]}}\n",
        "  ).limit(20):\n",
        "    print(json.dumps(document, indent=4, default=str))\n"
      ],
      "metadata": {
        "collapsed": true,
        "id": "3CVIpTayOaiu"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# 🔍 Run Query 4 with projection\n",
        "\n",
        "for document in collection.find(\n",
        "    {\"genres\": {'$in': [\"Adventure\", \"Comedy\"]}},\n",
        "    {\"title\": 1, \"genres\": 1, \"_id\": 0}\n",
        "  ).limit(20):\n",
        "    print(json.dumps(document, indent=4, default=str))"
      ],
      "metadata": {
        "collapsed": true,
        "id": "yY1ksiZMRJBy"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# 🔍 Run Aggregation Pipeline 1\n",
        "\n",
        "pipeline = [\n",
        "  {\n",
        "    \"$unwind\": \"$genres\"\n",
        "  },\n",
        "  {\n",
        "    \"$group\": {\n",
        "      \"_id\": \"null\",\n",
        "      \"distinctGenres\": {\n",
        "        \"$addToSet\": \"$genres\"\n",
        "      }\n",
        "    }\n",
        "  },\n",
        "  {\n",
        "    \"$project\": {\n",
        "      \"_id\": 0,\n",
        "      \"distinctGenres\": 1\n",
        "    }\n",
        "  }\n",
        "]\n",
        "\n",
        "for document in collection.aggregate(pipeline):\n",
        "    print(json.dumps(document, indent=4, default=str))"
      ],
      "metadata": {
        "collapsed": true,
        "id": "kCgxvQiGR0Y1"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# 🔍 Run Aggregation Pipeline 2\n",
        "\n",
        "pipeline = [\n",
        "  {\n",
        "    \"$unwind\": \"$genres\"\n",
        "  },\n",
        "  {\n",
        "    \"$group\": {\n",
        "      \"_id\": \"$genres\",\n",
        "      \"movies\": {\n",
        "        \"$push\": \"$title\"\n",
        "      }\n",
        "    }\n",
        "  },\n",
        "  {\n",
        "    \"$project\": {\n",
        "      \"genre\": \"$_id\",\n",
        "      \"movies\": {\n",
        "          \"$slice\": [\"$movies\", 5]\n",
        "          },\n",
        "      \"_id\": 0 }\n",
        "  }\n",
        "]\n",
        "\n",
        "for document in collection.aggregate(pipeline):\n",
        "    print(json.dumps(document, indent=4, default=str))"
      ],
      "metadata": {
